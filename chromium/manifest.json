{
  "manifest_version": 3,
  "name": "Visual Feedback Picker",
  "version": "0.1.0",
  "description": "Pick page elements, add notes, and copy selector feedback.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "offscreen",
    "scripting",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Visual Feedback Picker",
    "default_popup": "popup.html"
  }
}
